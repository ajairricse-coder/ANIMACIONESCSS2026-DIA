<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Visor de Realidad Aumentada</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Componente <model-viewer> de Google -->
  <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>

  <style>
    /* Estilos para adaptar el visor 3D al espacio de la pantalla */
    model-viewer {
      width: 100%;
      height: 450px;
      background-color: #f8f9fa;
      --poster-color: transparent;
      border-radius: 12px;
      overflow: hidden;
    }

    /* Botón flotante personalizable dentro de la escena AR */
    .ar-btn-custom {
      position: absolute;
      bottom: 16px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
    }
  </style>
</head>
<body class="bg-light">

  <!-- Navegación simple con Bootstrap -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="#">Experiencia WebAR</a>
    </div>
  </nav>

  <!-- Contenido Principal -->
  <main class="container my-4">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        
        <!-- Tarjeta Bootstrap -->
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <h2 class="h4 card-title fw-bold text-center mb-3">Modelo 3D Interactivo</h2>
            <p class="text-muted text-center mb-4">
              Pasa el dedo para rotar o haz zoom. En dispositivos móviles compatibles, presiona el botón para proyectar la animación en tu espacio.
            </p>

            <!-- Visor 3D y Realidad Aumentada -->
            <model-viewer 
              src="https://modelviewer.dev/shared-assets/models/Astronaut.glb" 
              ios-src="https://modelviewer.dev/shared-assets/models/Astronaut.usdz"
              alt="Modelo 3D animado"
              ar 
              ar-modes="webxr scene-viewer quick-look" 
              camera-controls 
              auto-rotate 
              autoplay
              shadow-intensity="1">
              
              <!-- Botón personalizado para lanzar Realidad Aumentada -->
              <button slot="ar-button" class="btn btn-primary btn-lg shadow ar-btn-custom">
                📱 Ver en Realidad Aumentada
              </button>

            </model-viewer>

          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- Bootstrap 5 JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
